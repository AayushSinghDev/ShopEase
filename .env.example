# ── Copy this file to .env and fill in your values ──────────────────────────

# Django
SECRET_KEY=shopease-change-this-to-something-random-50chars
DEBUG=False
ALLOWED_HOSTS=yourdomain.railway.app,localhost

# MySQL Database (Railway automatically sets these)
MYSQLDATABASE=shopease_db
MYSQLUSER=root
MYSQLPASSWORD=your_db_password
MYSQLHOST=localhost
MYSQLPORT=3306

# Razorpay (https://dashboard.razorpay.com)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic AI Chatbot (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# Gmail SMTP
# Step 1: Gmail → Settings → Security → 2-Step Verification → ON
# Step 2: Security → App Passwords → Select app: Mail → Generate
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=xxxx xxxx xxxx xxxx

# Face Recognition (local only — keep False on free servers)
FACE_RECOGNITION_ENABLED=False
